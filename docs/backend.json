
{
  "entities": {
    "Country": {
      "title": "Country",
      "description": "A country in the world tourism directory.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the country" },
        "code": { "type": "string", "description": "ISO country code" },
        "description": { "type": "string", "description": "Brief overview of the country" },
        "imageUrl": { "type": "string", "description": "Hero image for the country" },
        "region": { "type": "string", "description": "Geographical region" }
      },
      "required": ["name", "code"]
    },
    "City": {
      "title": "City",
      "description": "A major city within a country.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "countryId": { "type": "string", "description": "Reference to the parent country" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "population": { "type": "string" }
      },
      "required": ["name", "countryId"]
    },
    "Attraction": {
      "title": "Attraction",
      "description": "A tourist attraction or landmark in a city.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cityId": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "rating": { "type": "number" },
        "category": { "type": "string", "enum": ["Monument", "Nature", "Museum", "Park", "Historical", "Pilgrimage", "Beach", "Hill Station", "Wildlife", "Fort", "Resort"] },
        "googleMapsUrl": { "type": "string" },
        "timings": { "type": "string" },
        "entryFee": { "type": "string" }
      },
      "required": ["name", "cityId"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a guide or attraction.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "comment"]
    },
    "Guide": {
      "title": "Guide",
      "description": "A verified local guide profile.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "location": { "type": "string" },
        "languages": { "type": "string" },
        "aadharNumber": { "type": "string" },
        "panNumber": { "type": "string" },
        "passportNumber": { "type": "string" },
        "bio": { "type": "string" },
        "experience": { "type": "string" },
        "imageUrl": { "type": "string" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "location", "aadharNumber", "panNumber", "mobileNumber", "age", "gender", "isVerified"]
    },
    "Tourist": {
      "title": "Tourist",
      "description": "A detailed tourist profile.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "age": { "type": "number" },
        "aadharNumber": { "type": "string" },
        "panNumber": { "type": "string" },
        "passportNumber": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "interests": { "type": "string", "description": "Comma separated list of interests" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "age", "isVerified"]
    }
  },
  "auth": {
    "providers": ["google.com", "password", "anonymous"]
  },
  "firestore": {
    "/destinations/{destId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for attractions"
    },
    "/guides/{guideId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for specific guides"
    },
    "/users/{userId}": {
      "schema": "Tourist",
      "description": "Tourist profiles"
    }
  }
}
