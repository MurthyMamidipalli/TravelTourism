
{
  "entities": {
    "Country": {
      "title": "Country",
      "description": "A country in the world tourism directory.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the country" },
        "code": { "type": "string", "description": "ISO country code" },
        "description": { "type": "string", "description": "Brief overview of the country" },
        "imageUrl": { "type": "string", "description": "Hero image for the country" },
        "region": { "type": "string", "description": "Geographical region" }
      },
      "required": ["name", "code"]
    },
    "City": {
      "title": "City",
      "description": "A major city within a country.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "countryId": { "type": "string", "description": "Reference to the parent country" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "population": { "type": "string" }
      },
      "required": ["name", "countryId"]
    },
    "Attraction": {
      "title": "Attraction",
      "description": "A tourist attraction or landmark in a city.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "cityId": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "rating": { "type": "number" },
        "category": { "type": "string", "enum": ["Monument", "Nature", "Museum", "Park", "Historical"] },
        "googleMapsUrl": { "type": "string" }
      },
      "required": ["name", "cityId"]
    },
    "Review": {
      "title": "Review",
      "description": "A review for a guide.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "rating", "comment"]
    },
    "Guide": {
      "title": "Guide",
      "description": "A verified local guide profile.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "email": { "type": "string" },
        "mobileNumber": { "type": "string" },
        "age": { "type": "number" },
        "gender": { "type": "string", "enum": ["Male", "Female", "Other"] },
        "location": { "type": "string" },
        "languages": { "type": "string" },
        "aadharNumber": { "type": "string" },
        "panNumber": { "type": "string" },
        "bio": { "type": "string" },
        "experience": { "type": "string", "description": "A list of places explored or shown to tourists, including how many times (e.g., Tirumala - 10 times)." },
        "imageUrl": { "type": "string" },
        "specialty": { "type": "string" },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "isVerified": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "email", "location", "aadharNumber", "panNumber", "mobileNumber", "age", "gender", "experience"]
    }
  },
  "auth": {
    "providers": ["google.com", "password", "anonymous"]
  },
  "firestore": {
    "/countries/{countryId}": {
      "schema": "Country",
      "description": "Global countries collection"
    },
    "/countries/{countryId}/cities/{cityId}": {
      "schema": "City",
      "description": "Cities within a country"
    },
    "/countries/{countryId}/cities/{cityId}/attractions/{attractionId}": {
      "schema": "Attraction",
      "description": "Attractions within a city"
    },
    "/guides/{guideId}": {
      "schema": "Guide",
      "description": "Verified local guides collection"
    },
    "/guides/{guideId}/reviews/{reviewId}": {
      "schema": "Review",
      "description": "Reviews for a specific guide"
    }
  }
}
